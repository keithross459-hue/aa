# FiiLTHY.AI production environment template

# App
APP_ENV=production
BACKEND_URL=https://fiilthy-ai-production-backend.onrender.com
FRONTEND_URL=https://fiilthy-ai-production-frontend.vercel.app
CORS_ORIGINS=https://fiilthy.ai,https://www.fiilthy.ai
FORCE_HTTPS=true
RATE_LIMIT_PER_MINUTE=120

# Database
MONGO_URL=mongodb+srv://USER:PASSWORD@HOST/fiilthy
DB_NAME=fiilthy
BACKUP_DIR=backups

# Auth
JWT_SECRET=replace-with-strong-random-secret
JWT_PREVIOUS_SECRETS=
JWT_ISSUER=fiilthy.ai
JWT_AUDIENCE=fiilthy-app
OWNER_EMAIL=founder@example.com

# AI
EMERGENT_LLM_KEY=replace-me
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# Stripe
STRIPE_SECRET_KEY=sk_live_replace
STRIPE_WEBHOOK_SECRET=whsec_replace
STRIPE_PRICE_STARTER_USD=29
STRIPE_PRICE_PRO_USD=49.99
STRIPE_PRICE_ENTERPRISE_USD=299.99

# Email
SENDGRID_API_KEY=replace-me
SENDGRID_FROM_EMAIL=no-reply@fiilthy.ai
SENDGRID_FROM_NAME=FiiLTHY.AI

# Analytics / Monitoring
POSTHOG_API_KEY=replace-me
POSTHOG_HOST=https://app.posthog.com
SENTRY_DSN=
SENTRY_TRACES_SAMPLE_RATE=0.05

# Secrets / integration encryption
SETTINGS_ENC_KEY=replace-with-strong-random-secret
REFERRAL_PAYOUT_THRESHOLD_USD=50

# TikTok official APIs
TIKTOK_CLIENT_KEY=replace-after-rotating
TIKTOK_CLIENT_SECRET=replace-after-rotating
TIKTOK_BACKEND_URL=https://fiilthy-ai-production-backend.onrender.com
TIKTOK_REDIRECT_URI=https://fiilthy-ai-production-backend.onrender.com/api/auth/tiktok/callback
TIKTOK_SCOPES=user.info.basic,video.upload,video.publish
TIKTOK_MAX_UPLOAD_BYTES=67108864
ENABLE_TIKTOK_SCHEDULER=true
TIKTOK_SCHEDULER_INTERVAL_SECONDS=60

# Legal
LEGAL_COMPANY_NAME=FiiLTHY.AI
LEGAL_CONTACT_EMAIL=support@fiilthy.ai

# Frontend (Vercel)
REACT_APP_BACKEND_URL=https://fiilthy-ai-production-backend.onrender.com
REACT_APP_POSTHOG_KEY=replace-me
REACT_APP_POSTHOG_HOST=https://app.posthog.com
